// OOPS-- PIPLLAR OF OOPS
// Encapsulation-- means we r binding the data into a single unit(function, data, variable, method)
// into a single unit called class and making some restriction on this class member

// 20% are managed by encapsulation and 80% is managed by access specifier
// Need :
// 1) data security
// 2) controller access over my data
// 3) validation before accessing
// 4) code maintanability

// Q5.
#include <iostream>
using namespace std;
class BankAccount{
    private:
    int balance;
    public:
    void setBalance(int amount){
        if(amount >= 0 ){
            balance = amount;
        }
        else {
            cout << "Enter a valid numbe";
        }
    }
    public:
    int getBalance(){  // getter function
        return balance;
    }

};
int main(){
    BankAccount obj1;
    obj1.setBalance(5000);
    cout << obj1.getBalance();
}

