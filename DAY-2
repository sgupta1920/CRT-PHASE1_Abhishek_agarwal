// Q8. switch Statement
// customer support ivr system
// 1-- for support
// 2-- for billing
// 3-- for technical issue
// 4--talk to the agent

#include <iostream>
using namespace std;
int main(){
    int choice;
    cin >> choice;
    switch(choice){
        case 1:
        cout << "transferring call to the customer support";
        break;
        case 2: 
        cout << "transferring call to billing and accounts team";
        break;
        case 3: 
        cout << "Connecting to technical help desk";
        break;
        case 4:
        cout << "connecting call to the agent";
        break;
        default:
        cout << "invalid selection, enter a valid number";
    }
    
}











