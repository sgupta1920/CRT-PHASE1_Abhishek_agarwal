// Q1. count the number of binary string without consecutive one
// logic from logic series
// runs n to 1 so its a tail recursion

#include <iostream>
using namespace std;
void consecutiveOnes(int n){
    // base condition
    if(n==0){
        return 1;
    }
    if(n==1){
        return 2;
    }
    if(n==2){
        return 3;
    }
    // logic
    return consecutiveOnes(n-1) + consecutiveOnes(n-2);
}
int main(){
    cout << consecutiveOnes(10);
    return 0;
}


// Q2. find total combination where i is fix and j is varying

#include <iostream>
using namespace std;
int combination(int n){
    // base condition
    if(n<4){
        return 1;
    }
    if(n == 4){
        return 2;
    }
    // logic
    return combination(n-1) + combination(n-4);
}
int main(){
    cout << combination(10);
    return 0;
}


