// Q1. Access specifier
// 7.2) private

#include <iostream>
using namespace std;
class BankAccount{
    private: // can be accessed only inside class BankAccount
    int Balance = 5000;
    public:  // can be accessed anywhere in prog
    void ShowBalance(){
        cout << "Balance in your account is: " << Balance;
    }
};
int main(){
    BankAccount myaccount;  // object
    myaccount.ShowBalance();
}


// Q2. Access specifier
// 7.3) protected

#include <iostream>
using namespace std;
class Parent{
    protected:
    int secretCode = 1234;
};
class child : public Parent{   // inheritance
    public:
    void AccessOfSecretCode(){
        cout << "secretCode of the locker is " << secretCode;
    }
};
int main(){
    child obj1;
    obj1.AccessOfSecretCode();
}

