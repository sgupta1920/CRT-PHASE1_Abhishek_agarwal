// eg2.

// virtual funtion: same function name, same parameter but is virtual

#include <iostream>
using namespace std;
class Parent{
    public:
    virtual void sum(int a, int b){
        cout << a+b << " "<< "Parent "<<"\n";
    }
};
class child : public Parent{
    public:
    void sum (int a, int b) override{
        cout << a+b << " " <<"Child" <<"\n";
    }
};
int main(){
    child c;
    c.sum(4,6);
}










