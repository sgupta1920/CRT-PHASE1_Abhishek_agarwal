// Q5. function overloading
// same function name, different Argument(parameter)

#include<iostream>
using namespace std;
int add(int a, int b){
    return a+b;
}
int add(int a, int b, int c){
    return a+b+c;
}
int add(int a, int b, int c, int d){
    return a+b+c+d;
}
double add(double a, double b){
    return a+b;
}
int main(){
    cout << add(5,2) << "\n";
    cout << add(5,2,3) << "\n";
    cout << add(5,2,3,4) << "\n";
    cout << add(5.5, 2.0);
    return 0;
}


// Q6. Pointers

#include <iostream>
using namespace std;
int main(){
    int age=24;
    int *ptr = &age;
    cout << age << "\n";
    cout << ptr << "\n";  // address of the variable 
    cout << *ptr << "\n";  // value of the pointer 
    // dereferencing of pointer
    *ptr = 28; // changing of variable value using pointer
    cout << *ptr << "\n";
}


