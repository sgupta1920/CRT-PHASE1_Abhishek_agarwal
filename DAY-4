// PATTERN PRINTING

// Q1. print 1 to 10, 10 numbers of times

#include<iostream>
using namespace std;
int main(){
    for(int i=1; i <= 10; i++){  // outer for loop defines the number of rows. 
        // defines what to print in the pattern
        for(int j=1; j <= 10; j++){
            cout << j << " ";
        }
        cout << "\n";
    }
    return 0;
}


