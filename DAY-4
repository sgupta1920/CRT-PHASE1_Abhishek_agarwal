// Q6. hollow square
// *****
// *   *
// *   *
// *   *
// *****

#include<iostream>
using namespace std;
int main(){
    int n;
    cin >> n;
    for(int i=1; i <= n; i++){ 
        for(int j=1; j <= n; j++){
            cout << " ";
            if((i == 1) || (j == 1) || (i == n) || (j == n)){
                cout << "*";
            }
            else {
                cout << " ";
            }
        }
        cout << "\n";
    }
    return 0;
}


// Q7. pyramid
//    *
//   ***
//  *****
// *******

// difference b/w this pyramid and mirror right angle triangl is space before printing " *""
#include<iostream>
using namespace std;
int main(){
    int n;
    cin >> n;
    // number of times or number of rows
    for(int i=1; i <= n; i++){
        // number of spaces logic is here
        for(int j = 1; j <= n-i; j++){
            cout << " ";
        }
        for(int k=1; k <= i ; k++){
            cout << " *";
        }
        cout << "\n";
    }
}















