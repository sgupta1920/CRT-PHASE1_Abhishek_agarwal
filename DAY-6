// Q1. Swapping of values of 2 variables using swap function

#include <iostream>
using namespace std;
// using function type 
// argument, no return 
void swapNumber(int *x, int *y){
    int temp = *x;
    *x = *y;
    *y = temp;
}
int main(){
    int a, b;
    cin >> a;
    cin >> b;
    swapNumber(&a, &b);
    cout << a << " " << b;
}


