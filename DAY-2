// Q1. IF CONDITION
to verify user age weather eligible for vote or not

#include <iostream>
using namespace std;
int main(){
    int age;
    cin >> age;
    if(age >= 18){
        cout << "Eligible for vote";
    }
    return 0;
}


// Q2. IF-ELSE CONDITION
// to verify user age weather eligible for vote or not

#include <iostream>
using namespace std;
int main(){
    int age;
    cin >> age;
    if(age >= 18){
        cout << "Eligible for vote";
    }
    else{
        cout << " Not eligible for vote";
    }
    return 0;
}


// Q3. nested if else 

#include <iostream>
using namespace std;

int main() {
    int age;
    cin >> age;

    if (age >= 18) {
        if (age >= 100) {
            cout << "eligible for vote (but you are a super senior citizen)";
        } else {
            cout << "eligible for vote";
        }
    } else {
        if (age < 0) {
            cout << "enter a valid age number";
        } else {
            cout << "not eligible for vote";
        }
    }

    return 0;
}

// Q4. Ternary operator 
// find the greater number among 2

#include <iostream>
using namespace std;
int main(){
    int a, b;
    int max_number;
    cin >> a >> b;
    // Ternary operator
    max_number = (a > b) ? a : b; // ? is a if-else cond, if a>b then print a else print b
    cout << max_number;
    return 0;
}

// Q5 continue Statement 
// print 1 to n and avoid number which are divisible by 3

#include <iostream>
using namespace std;
int main(){
    int n;
    cin >> n;
    for(int i=1; i <= n; i++){
        if(i % 3 == 0){
            continue;
        }
            cout << i << " ";
    }
    cout << "\n";
    return 0;
}


// Q6. break Statement
// we have to add numbers until we get a negative number

#include <iostream>
using namespace std;
int main(){
    int n;
    int sum=0;
    while(true){
        cin >> n;
        if(n < 0){
            break;
        }
        sum += n;
    }
    cout << sum;
    return 0;
}


