// Q3. 
// call by value - photocopy - will never update the original data
// call by reference - original

#include <iostream>
using namespace std;
// argument, no return type
void updatebyValue(int a){
    a = 500;
}
void updatebyReference(int &a){
    a = 500;
}
int main(){
    int original = 100; 
    cout << original << "\n";
    updatebyValue(original);
    cout << original << "\n";
    updatebyReference(original);
    cout << original;
}


