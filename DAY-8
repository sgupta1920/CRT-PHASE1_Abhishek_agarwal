// Q1. Inheritance
// types of Inheritance
// 1.1)  single Inheritance

#include <iostream>
using namespace std;
class Vehicle{
    public:
    void start(){
        cout << "Vehicle starts" << "\n";
    }
};
class Car : public Vehicle{
    public:
    void drive(){
        cout << "Car is running" << "\n";
    }
};
int main(){
    Car obj1;
    obj1.drive();
    obj1.start();
}


// 1.2) Multilevel Inheritance

#include <iostream>
using namespace std;
class Vehicle{
    public:
    void start(){
        cout << "Vehicle starts" << "\n";
    }
};
class Car : public Vehicle{
    public:
    void drive(){
        cout << "Car is running" << "\n";
    }
};
class SpeedoMeter: public Car {
    public:
    void speed(){
        cout << "car is running at 60 km/h" << "\n";
        
    }
};
int main(){ 
    SpeedoMeter obj1;   // object child ka ka banega
    obj1.drive();  // parent class ka fiunction
    obj1.start();  // grandparent ka function
    obj1.speed();  // khud ka 
}


// 1.3) hierarchial Inheritance


#include <iostream>
using namespace std;
class Vehicle{
    public:
    void start(){
        cout << "Vehicle starts" << "\n";
    }
};
class Car : public Vehicle{
    public:
    void drive(){
        cout << "Car is running" << "\n";
    }
};
class bike: public Vehicle {
    public:
    void drive1(){
        cout << "bike is running" << "\n";
        
    }
};
int main(){ 
    Car obj1; 
    bike obj2;
    obj1.drive();  
    obj1.start();
    obj2.drive1(); 
    obj2.start();
}


// 1.4) Multilevel Inheritance  (IMP)
// ambig error : same function name called by a child class


#include <iostream>
using namespace std;
class Parent1{
    public:
    void giveMeMoney(){
        cout << "Mom give me money" << "\n";
    }
};
class Parent2{
    public:
    void giveMeMoney(){
        cout << "papa give me money" << "\n";
    }
};
class Child: public Parent1, public Parent2 {
    // no logic
};
int main(){ 
    Child obj1; 
    obj1.Parent1::giveMeMoney();
    obj1.Parent2::giveMeMoney();
}


// 1.5) Hybrid Inheritance

#include <iostream>
using namespace std;
class A{
    public:
    void print(){
        cout << "Wons" << "\n";
    }
};
class B : virtual public A{
   // No logic
};
class C : virtual public A{
    // No logic
};
class D: public B, public C {
    // no logic
};
int main(){ 
    D obj1; 
    obj1.print();
}


